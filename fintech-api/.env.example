NODE_ENV=development
PORT=4101

# Table for auth-aligned user ids (wallet FK checks): fintech_auth_users (property app) or users (full fintech schema)
# FINTECH_USER_TABLE=fintech_auth_users

# Prefer a single connection string (Supabase: Project Settings → Database → URI, use pooler :6543 for server apps).
# Example (replace YOUR_PASSWORD and host):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Only if DATABASE_URL is unset — use real credentials; placeholders like PGUSER=user will fail with 28P01.
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_real_password
# PGDATABASE=postgres

# Flutterwave (server only — never expose secret key to the browser)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
# Ledger UUID for FW_CLEARING (optional if accounts.code = FW_CLEARING exists)
# FLUTTERWAVE_CLEARING_ACCOUNT_ID=
# Ledger UUID for WITHDRAWAL_SUSPENSE (optional if accounts.code = WITHDRAWAL_SUSPENSE exists — see sql/withdrawal_extensions.sql)
# WITHDRAWAL_SUSPENSE_ACCOUNT_ID=

# Escrow (rent hold + commission)
# DEFAULT_ESCROW_HOLD_DAYS=7
# PLATFORM_COMMISSION_ACCOUNT_ID=
# Cap rent commission (basis points; 1000 = 10%)
# COMMISSION_MAX_BPS=1000

# JWT (HS256) — use strong secret in production
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ISSUER=damianixpro-fintech
# Optional: require matching JWT aud claim
# JWT_AUDIENCE=damianixpro-fintech
# Clock skew tolerance (seconds) for iat/exp
# JWT_CLOCK_TOLERANCE_SEC=30

# Optional: skip JWT in dev (never in production)
# AUTH_DEV_BYPASS=true
# When bypassing auth, optional real UUID for public.users FK tests
# AUTH_DEV_USER_ID=

# Rate limits (per window)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_IP_MAX=200
# RATE_LIMIT_WEBHOOK_MAX=3000
# RATE_LIMIT_SENSITIVE_MAX=30

# Behind reverse proxy (for accurate req.ip in rate limits)
# TRUST_PROXY=true
