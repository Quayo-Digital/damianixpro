# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Nigerian API Integration Configuration
# =====================================================

# YouVerify API (BVN, NIN, Phone Verification)
# Get your API key from: https://youverify.co
VITE_YOUVERIFY_API_KEY=your_youverify_api_key
VITE_YOUVERIFY_BASE_URL=https://api.youverify.co/v2

# Appruve API (CAC Business Verification)
# Get your API key from: https://appruve.co
VITE_APPRUVE_API_KEY=your_appruve_api_key
VITE_APPRUVE_BASE_URL=https://api.appruve.co/v1

# Paystack API (Bank Account Verification & Payments)
# Get your API key from: https://paystack.com
VITE_PAYSTACK_SECRET_KEY=your_paystack_secret_key
VITE_PAYSTACK_BASE_URL=https://api.paystack.co

# Flutterwave API (Alternative Payment Provider)
# Get your API key from: https://flutterwave.com
VITE_FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
VITE_FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# MapTiler Configuration (Super Admin Only)
# Get your API key from: https://www.maptiler.com/cloud/plans/
VITE_MAPTILER_API_KEY=your_maptiler_api_key

# Other Configuration
VITE_APP_NAME=Nigeria Homes
VITE_APP_VERSION=1.0.0
