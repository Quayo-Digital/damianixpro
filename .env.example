# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: inject CSP meta tag in production (src/utils/security.ts). Off unless VITE_ENABLE_RUNTIME_CSP=true.
# When on, script-src includes unsafe-eval by default (avoids DevTools CSP/eval warnings with some SDKs). Set VITE_CSP_ALLOW_UNSAFE_EVAL=false to drop it.
# VITE_ENABLE_RUNTIME_CSP=true
# VITE_CSP_ALLOW_UNSAFE_EVAL=false

# Optional: if your DB has no public.lease_agreements table, set to skip the initial REST probe (no 404 in Network tab).
# After the first successful visit we also persist "missing" in sessionStorage.
# VITE_LEASE_SOURCE=leases
SUPABASE_SERVICE_ROLE_KEY=
# Server-side only — never use a VITE_ prefix for this key.
SUPABASE_URL=
SUPABASE_JWT_SECRET=
VITE_VOICE_SERVER_URL=http://localhost:4000
# Executive analytics API (GET /api/analytics/executive). Defaults to VITE_VOICE_SERVER_URL when unset
# so existing single-host deployments keep working. Set this if analytics is hosted separately.
# VITE_ANALYTICS_API_URL=http://localhost:4000
# Voice/payment sidecar listen port (server/index.mjs). Used by smoke:payment-rent when PUBLIC_PAYMENT_BASE_URL is unset.
# VOICE_SERVER_PORT=4000
# Base URL for scripts/smoke-payment-rent-routes.mjs (POST /api/payments/rent + webhook). Defaults to http://127.0.0.1:${VOICE_SERVER_PORT}.
# PUBLIC_PAYMENT_BASE_URL=http://127.0.0.1:4000
# Floating support AI chat (uses VITE_VOICE_SERVER_URL + /api/support/chat). Set to false to hide.
# VITE_ENABLE_SUPPORT_CHAT=true

# Voice/payment sidecar (server/index.mjs, server/ttsServer.mjs): CORS allowlist (comma-separated) or * (default, dynamic reflect).
# VOICE_SERVER_CORS_ORIGIN=https://your-app.example
# Optional rate limits (defaults: 300 requests / 60s per IP)
# VOICE_SERVER_RATE_LIMIT_MAX=300
# VOICE_SERVER_RATE_LIMIT_WINDOW_MS=60000

# Nigerian API Integration Configuration
# =====================================================
# Provider secret keys must be stored server-side using Supabase secrets:
# supabase secrets set YOUVERIFY_API_KEY=xxx APPRUVE_API_KEY=xxx FLUTTERWAVE_SECRET_KEY=xxx

# YouVerify API (BVN, NIN, Phone Verification)
# Get your API key from: https://youverify.co (store as YOUVERIFY_API_KEY server secret)
VITE_YOUVERIFY_BASE_URL=https://api.youverify.co/v2

# Appruve API (CAC Business Verification)
# Get your API key from: https://appruve.co (store as APPRUVE_API_KEY server secret)
VITE_APPRUVE_BASE_URL=https://api.appruve.co/v1

# Flutterwave API (Primary Payment Provider)
# Get your API key from: https://flutterwave.com
# IMPORTANT: Use PUBLIC key only in frontend. Secret key goes in Supabase secrets.
# Run: supabase secrets set FLUTTERWAVE_SECRET_KEY=FLWSECK_xxx
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key
VITE_FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Flutterwave server-side (for rent payment API)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
PAYMENT_REDIRECT_URL=https://yourdomain.com/api/payments/callback
PAYMENT_LOGO_URL=https://yourdomain.com/logo.png
APP_DEEP_LINK_SCHEME=damianixpro

# Map (Leaflet): uses OpenStreetMap tiles by default; no key required.
# Optional: MapTiler tiles (set key below) for an alternative style.
# Get your API key from: https://www.maptiler.com/cloud/plans/
VITE_MAPTILER_API_KEY=

# Payment Notifications (Email, SMS, WhatsApp)
RESEND_API_KEY=
RESEND_FROM_EMAIL=DamianixPro <notifications@damianixpro.com>

# AI Rent Reminder System (Twilio + Paystack)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PAYSTACK_SECRET_KEY=
RENT_REMINDER_DAYS_AHEAD=5
PUBLIC_BASE_URL=https://your-domain.com

# AI Financial Assistant & Voice (OpenAI)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: model for POST /api/support/chat (default gpt-4o-mini)
# OPENAI_SUPPORT_MODEL=gpt-4o-mini
# NL assistant POST /api/ai/query: when rules miss, call OpenAI for intent (needs OPENAI_API_KEY)
# AI_QUERY_OPENAI_FALLBACK=true
# OPENAI_AI_QUERY_MODEL=gpt-4o-mini

# Notification outbox worker: POST /api/notifications/outbox/process with header x-notification-worker-secret
# NOTIFICATION_WORKER_SECRET=change-me-in-production
# Optional: SMS_PROVIDER=noop (log only; default uses Twilio when TWILIO_* set)
# Cron: node scripts/drain-notification-outbox.mjs 80   (needs VOICE_SERVER_URL + NOTIFICATION_WORKER_SECRET)

# WhatsApp Voice Assistant (DamianixPro)
# Get from Meta for Developers > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=damianixpro-voice
VOICE_SERVER_URL=http://localhost:4000
TTS_URL=http://localhost:4010

# Web Push (VAPID) — generate keys: npx web-push generate-vapid-keys
# Public key in the SPA; private key only on the server (voice service) that sends pushes.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional contact for VAPID (mailto: or https:)
# VAPID_SUBJECT=mailto:support@yourdomain.com

# Optional: Supabase Database Webhook → POST to your voice server when rows insert into `notifications`
# Set the same value in Supabase webhook headers and here.
# PUSH_WEBHOOK_SECRET=

# Other Configuration
VITE_APP_NAME=Nigeria Homes
VITE_APP_VERSION=1.0.0
# Optional: only if you deploy a separate Nigerian market-data / listings API (see NigerianRealEstateDataService). Leave unset to avoid calling a default host.
# VITE_API_BASE_URL=https://your-api.example
